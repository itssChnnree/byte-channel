    <!--新增所有列-->
    <insert id="insert" keyProperty="id" useGeneratedKeys="true">
        insert into ticket_main_text(id, ticket_id, user_id,user_name, ticket_main_text, status, is_deleted, create_user,
                                     update_user, create_time, update_time)
        values (#{id}, #{ticketId}, #{userId},#{userName}, #{ticketMainText}, #{status}, #{isDeleted}, #{createUser},
