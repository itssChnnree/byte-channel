    <!--��ѯ����-->
    <select id="queryById" resultMap="TicketMainTextVOMap">
        select id,
               ticket_id,
               user_id,
               ticket_main_text,
               status,
               is_deleted,
               create_user,
               update_user,
               create_time,
               update_time
        from ticket_main_text
        where id = #{id}
          and is_deleted = 0
    </select>

    <!--��ѯָ��������-->
    <select id="queryList" resultMap="TicketMainTextVOMap">
        select
        id, ticket_id, user_id, ticket_main_text, status, is_deleted, create_user, update_user, create_time, update_time
        from ticket_main_text
        <where>
            1 = 1 and is_deleted = 0
            <if test="id != null and id != ''">
                and id = #{id}
            </if>
            <if test="ticketId != null and ticketId != ''">
                and ticket_id = #{ticketId}
            </if>
            <if test="userId != null and userId != ''">
                and user_id = #{userId}
            </if>
            <if test="ticketMainText != null and ticketMainText != ''">
                and ticket_main_text = #{ticketMainText}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="isDeleted != null">
                and is_deleted = #{isDeleted}
            </if>
            <if test="createUser != null and createUser != ''">
                and create_user = #{createUser}
            </if>
            <if test="updateUser != null and updateUser != ''">
                and update_user = #{updateUser}
            </if>
            <if test="createTime != null">
                and create_time = #{createTime}
            </if>
            <if test="updateTime != null">
                and update_time = #{updateTime}
            </if>
        </where>
    </select>

